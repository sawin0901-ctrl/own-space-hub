generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Source {
  DIGISELLER
  PLATI
}

enum Role {
  ADMIN
}

enum ImportStatus {
  IDLE
  RUNNING
  PAUSED
  ERROR
}

enum ImportItemStatus {
  IMPORTED
  UPDATED
  SKIPPED
  NOT_FOUND
  ERROR
}

model Category {
  id              String     @id @default(cuid())
  slug            String     @unique
  name            String
  parentId        String?
  parent          Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children        Category[] @relation("CategoryTree")
  sortOrder       Int        @default(0)
  seoTitle        String?
  seoDescription  String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  products        Product[]
}

model Product {
  id            String   @id @default(cuid())
  source        Source
  externalId    String
  slug          String   @unique
  title         String
  description   String?  @db.Text
  price         Decimal  @db.Decimal(12, 2)
  oldPrice      Decimal? @db.Decimal(12, 2)
  currency      String   @default("RUB")
  image         String?
  gallery       String[] @default([])
  rating        Float    @default(0)
  reviewsCount  Int      @default(0)
  sellerName    String?
  sellerUrl     String?
  platform      String?
  publisher     String?
  region        String?
  genres        String[] @default([])
  categoryId    String?
  category      Category? @relation(fields: [categoryId], references: [id])
  affiliateUrl  String
  isActive      Boolean  @default(true)
  lastSyncedAt  DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  views   ProductView[]
  clicks  AffiliateClick[]
  reviews Review[]

  @@unique([source, externalId])
  @@index([categoryId])
  @@index([platform])
  @@index([publisher])
  @@index([isActive])
}

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  author    String
  rating    Int
  text      String   @db.Text
  createdAt DateTime @default(now())

  @@index([productId])
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model ProductView {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  ipHash    String?
  userAgent String?
  referer   String?
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([createdAt])
}

model AffiliateClick {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  ipHash    String?
  userAgent String?
  referer   String?
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([createdAt])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
}

// Состояние бесконечного импорта по ID (один источник = одна строка)
model ImportState {
  id              String        @id @default(cuid())
  source          Source        @unique
  status          ImportStatus  @default(IDLE)
  startId         Int           @default(1)
  cursorId        Int           @default(0)   // последний проверенный ID
  maxId           Int?                         // null = бесконечно
  concurrency     Int           @default(1)   // параллельных запросов
  delayMs         Int           @default(2000) // пауза между батчами
  recheckHours    Int           @default(24)  // период ре-чека существующих
  dailyLimit      Int           @default(200) // максимум импортов за 24 часа (0 = без лимита)
  totalChecked    Int           @default(0)
  totalImported   Int           @default(0)
  totalSkipped    Int           @default(0)
  totalErrors     Int           @default(0)
  lastError       String?
  lastRunAt       DateTime?
  updatedAt       DateTime      @updatedAt
  createdAt       DateTime      @default(now())
}

model ImportLog {
  id          String           @id @default(cuid())
  source      Source
  externalId  String
  status      ImportItemStatus
  message     String?
  productId   String?
  createdAt   DateTime         @default(now())

  @@index([source, createdAt])
  @@index([status, createdAt])
}
