# База данных
POSTGRES_USER=gameplaza
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=gameplaza
DATABASE_URL=postgresql://gameplaza:changeme_strong_password@postgres:5432/gameplaza?schema=public

# Redis
REDIS_URL=redis://redis:6379

# Приложение
NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://gameplaza.site

# Безопасность
# Сгенерируйте: openssl rand -hex 32
AUTH_SECRET=change_me_to_random_64_hex
# Соль для хеширования IP в аналитике (любая случайная строка)
IP_HASH_SALT=change_me_random

# Первичный администратор (создаётся при первом запуске, если таблица пустая)
ADMIN_EMAIL=admin@gameplaza.site
ADMIN_PASSWORD=changeme_admin_password

# Партнёрский ID по умолчанию (можно менять в админке)
DEFAULT_AFFILIATE_ID=

# Интервал синхронизации товаров (минуты)
SYNC_INTERVAL_MINUTES=60

# --- Источники товаров ---
# Digiseller (https://my.digiseller.com/) — для получения товаров через API.
DIGISELLER_SELLER_ID=
DIGISELLER_API_KEY=

# Plati.market — API ключ продавца / партнёра.
PLATI_API_KEY=
PLATI_SELLER_ID=
